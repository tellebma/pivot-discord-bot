# ============================================================
# Configuration Discord (obligatoire)
# ============================================================
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Environnement d'exécution : development | production
NODE_ENV=development

# ============================================================
# Relecture de Pull Requests
# ============================================================
# ID(s) des canaux Discord surveillés pour les liens de PR GitHub.
# Séparez plusieurs IDs par des virgules. Laisser vide = surveillance désactivée
# (la commande /review reste disponible).
PR_REVIEW_CHANNEL_ID=

# Token GitHub : lecture des PR par le bot, et utilisé par la CLI `gh` pour que
# l'agent de relecture approuve la PR ou demande des changements. Prévoir une
# portée "repo" avec droit d'écriture sur les Pull Requests.
GITHUB_TOKEN=

# Base de l'API GitHub. À personnaliser uniquement pour GitHub Enterprise.
GITHUB_API_URL=https://api.github.com

# Répertoire des clones locaux du code des PR relues (un clone persistant par
# dépôt, réutilisé comme cache). L'agent y lit le code en LECTURE SEULE.
# Laisser la variable ABSENTE = défaut (.review-workspace). La définir VIDE
# désactive le checkout local : la relecture passe alors uniquement par `gh`.
PR_REVIEW_WORKSPACE_DIR=.review-workspace

# Outils autorisés pour l'agent de relecture : la CLI GitHub (`gh pr ...` et
# `gh api ...`) pour consulter/approuver/commenter la PR, et Read/Grep/Glob
# pour explorer le checkout local en lecture seule.
PR_REVIEW_ALLOWED_TOOLS=Bash(gh pr:*),Bash(gh api:*),Read,Grep,Glob

# Nombre maximal de tours de l'agent de relecture (borne le coût).
PR_REVIEW_MAX_TURNS=20

# ============================================================
# CLI Claude (installée sur la machine hôte)
# ============================================================
# Chemin ou nom de la commande de la CLI Claude.
CLAUDE_CLI_PATH=claude

# Modèle Claude à utiliser (optionnel : laisse le défaut de la CLI si vide).
CLAUDE_CLI_MODEL=

# Arguments supplémentaires passés à la CLI Claude (séparés par des espaces).
# Exemple : --permission-mode plan
CLAUDE_CLI_EXTRA_ARGS=

# Délai maximal d'une relecture avant abandon (millisecondes).
CLAUDE_REVIEW_TIMEOUT_MS=300000

# Authentification de la CLI Claude (lue par le sous-processus `claude`).
# Option recommandée en conteneur/serveur : renseigner une clé API.
# (Alternative : abonnement Claude via montage de ~/.claude — voir DEPLOYMENT.md.)
ANTHROPIC_API_KEY=

# ============================================================
# Commande /ask — recherche métier sur le code Pivot
# ============================================================
# Chemin du checkout LOCAL du code Pivot (branche main) que Claude Code va
# explorer en LECTURE SEULE. Laisser vide désactive la commande /ask.
# En déploiement Docker (Option A), laisser /pivot (fixé par docker-compose) et
# renseigner plutôt PIVOT_SRC_PATH ci-dessous.
ASK_REPO_PATH=

# (Docker uniquement) Chemin HÔTE du code Pivot, monté en lecture seule sur
# /pivot dans le conteneur. Défaut : /srv/pivot-src.
PIVOT_SRC_PATH=/srv/pivot-src

# Modèle Claude pour /ask (optionnel : retombe sur CLAUDE_CLI_MODEL sinon).
ASK_CLAUDE_MODEL=

# Outils autorisés (lecture seule). Garde-fou : ne PAS ajouter Write/Edit/Bash.
ASK_ALLOWED_TOOLS=Read,Grep,Glob

# Nombre maximal de tours d'exploration (borne le coût).
ASK_MAX_TURNS=30

# Délai maximal d'une recherche métier (millisecondes).
ASK_TIMEOUT_MS=300000

# Longueur maximale d'une question (caractères).
ASK_MAX_QUESTION_LENGTH=500

# ============================================================
# Observabilité (optionnel)
# ============================================================
# Laisser vide pour désactiver Sentry.
SENTRY_DSN=
