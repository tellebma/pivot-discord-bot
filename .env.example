# ============================================================
# Configuration Discord (obligatoire)
# ============================================================
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Environnement d'exécution : development | production
NODE_ENV=development

# ============================================================
# Relecture de Pull Requests
# ============================================================
# ID(s) des canaux Discord surveillés pour les liens de PR GitHub.
# Séparez plusieurs IDs par des virgules. Laisser vide = surveillance désactivée
# (la commande /review reste disponible).
PR_REVIEW_CHANNEL_ID=

# Token GitHub optionnel (dépôts privés / limites de débit plus élevées).
# Un token à portée "repo" (lecture) suffit.
GITHUB_TOKEN=

# Base de l'API GitHub. À personnaliser uniquement pour GitHub Enterprise.
GITHUB_API_URL=https://api.github.com

# Taille maximale du diff (en caractères) envoyé à l'agent. Au-delà, le diff
# est tronqué et l'agent en est informé.
PR_REVIEW_MAX_DIFF_CHARS=200000

# ============================================================
# CLI Claude (installée sur la machine hôte)
# ============================================================
# Chemin ou nom de la commande de la CLI Claude.
CLAUDE_CLI_PATH=claude

# Modèle Claude à utiliser (optionnel : laisse le défaut de la CLI si vide).
CLAUDE_CLI_MODEL=

# Arguments supplémentaires passés à la CLI Claude (séparés par des espaces).
# Exemple : --permission-mode plan
CLAUDE_CLI_EXTRA_ARGS=

# Délai maximal d'une relecture avant abandon (millisecondes).
CLAUDE_REVIEW_TIMEOUT_MS=300000

# ============================================================
# Observabilité (optionnel)
# ============================================================
# Laisser vide pour désactiver Sentry.
SENTRY_DSN=
