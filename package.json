{
  "name": "pivot-discord-bot",
  "version": "0.1.0",
  "description": "Bot Discord de relecture automatisée de Pull Requests GitHub via la CLI Claude",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist coverage",
    "prebuild": "npm run clean",
    "validate": "npm run format:check && npm run lint && npm run type-check && npm run test && npm run build"
  },
  "keywords": [
    "discord",
    "bot",
    "github",
    "pull-request",
    "code-review",
    "claude",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.64.0",
    "cron": "^4.4.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.4",
    "rimraf": "^5.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
