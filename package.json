{
  "name": "pivot-discord-bot",
  "version": "0.1.0",
  "description": "Bot Discord de relecture automatisée de Pull Requests GitHub via la CLI Claude",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "discord",
    "bot",
    "github",
    "pull-request",
    "code-review",
    "claude",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^8.55.2",
    "cron": "^4.4.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "rimraf": "^5.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
